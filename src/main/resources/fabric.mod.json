{
  "schemaVersion": 1,
  "id": "compsnow",
  "version": "${version}",
  "name": "Nova Reimagined Snow",
  "description": "Provides accurate per-block biome snow detection and snow texture variant support for the Nova Reimagined shader pack. Eliminates snow tinting bleed across biome borders and resolves snow surface textures from your active resource packs for use by the shader.",
  "authors": [
    "ItsThatNova"
  ],
  "contact": {
    "homepage": "https://github.com/ItsThatNova/complementary-snow",
    "sources": "https://github.com/ItsThatNova/complementary-snow",
    "issues": "https://github.com/ItsThatNova/complementary-snow/issues"
  },
  "license": "MIT",
  "icon": "assets/compsnow/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.itsthatnova.compsnow.CompSnowClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.5",
    "fabric-api": "*",
    "minecraft": "~1.21"
  },
  "suggests": {
    "iris": "*",
    "distanthorizons": "*",
    "seasoncache": "*"
  }
}